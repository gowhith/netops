# --- App ---
APP_NAME=NetOps AI
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- API ---
# Ports chosen to NOT collide with Altrion (uses 8001/8002/8004/8005 and 5500).
API_HOST=0.0.0.0
API_PORT=8020
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5500,http://127.0.0.1:5500,http://127.0.0.1:5501,http://localhost:5510,http://127.0.0.1:5510

# --- Database (Postgres + Timescale extension on same instance) ---
# Host port 5433 to avoid Altrion's Postgres on 5432.
POSTGRES_USER=netops
POSTGRES_PASSWORD=netops
POSTGRES_DB=netops
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+asyncpg://netops:netops@localhost:5433/netops

# --- Redis ---
# Host port 6380 to avoid Altrion's Redis on 6379.
REDIS_URL=redis://localhost:6380/0
TELEMETRY_STREAM=telemetry:events
TELEMETRY_CONSUMER_GROUP=telemetry-workers
TELEMETRY_CONSUMER_NAME=worker-1

# --- Security ---
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Rules / thresholds ---
RULE_CPU_WARNING=75
RULE_CPU_CRITICAL=90
RULE_MEM_WARNING=80
RULE_MEM_CRITICAL=92
RULE_LATENCY_WARNING_MS=120
RULE_LATENCY_CRITICAL_MS=200
RULE_PACKET_LOSS_WARNING=2.0
RULE_PACKET_LOSS_CRITICAL=5.0
HEARTBEAT_OFFLINE_SECONDS=30

# --- Simulator ---
SIM_DEVICE_COUNT=20
SIM_INTERVAL_SECONDS=3
SIM_API_URL=http://localhost:8020
